enum PartnerWebhookEvent {
  SCHEDULE_UPDATED
  RESULTS_UPDATED
  // Intelligence API events
  DATA_IMPORTED
  EMBEDDINGS_READY
  RECOMMENDATIONS_GENERATED
}

model Partner {
  id              String       @id @default(uuid())
  name            String
  code            String       @unique // Short unique identifier
  contactEmail    String?      @map("contact_email")
  contactName     String?      @map("contact_name")
  directorUserId  String?      @map("director_user_id") // Tournament director who manages tournaments
  status          PartnerStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  apps            PartnerApp[]
  externalMappings ExternalIdMapping[]
  apiRequestLogs  ApiRequestLog[]
  webhooks        PartnerWebhook[]
  clubBindings    PartnerClubBinding[]
  director        User?        @relation(fields: [directorUserId], references: [id], onDelete: SetNull)

  @@index([directorUserId])
  @@map("partners")
}

model PartnerClubBinding {
  id        String   @id @default(uuid())
  partnerId String   @map("partner_id")
  clubId    String   @map("club_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([partnerId, clubId])
  @@index([partnerId])
  @@index([clubId])
  @@map("partner_club_bindings")
}

model PartnerWebhook {
  id        String               @id @default(uuid())
  partnerId String               @map("partner_id")
  eventType PartnerWebhookEvent  @map("event_type")
  url       String
  secret    String
  isActive  Boolean              @default(true) @map("is_active")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  partner   Partner              @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, eventType])
  @@map("partner_webhooks")
}

model PartnerApp {
  id              String       @id @default(uuid())
  partnerId       String       @map("partner_id")
  environment     PartnerEnvironment
  keyId           String       @unique @map("key_id") // Public identifier
  secretHash      String       @map("secret_hash") // Hashed secret (bcrypt)
  lastUsedAt      DateTime?    @map("last_used_at")
  status          PartnerAppStatus @default(ACTIVE)
  allowedIps      String[]    @default([]) @map("allowed_ips") // IP allowlist (empty = no restriction)
  rateLimitRpm    Int         @default(60) @map("rate_limit_rpm") // Requests per minute
  scopes          String[]    @default([]) // e.g., ["indyleague:write", "indyleague:read"]
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  partner         Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  apiRequestLogs  ApiRequestLog[]
  idempotencyKeys IdempotencyKey[]

  @@map("partner_apps")
}

model ExternalIdMapping {
  id              String       @id @default(uuid())
  partnerId       String       @map("partner_id")
  entityType      ExternalEntityType @map("entity_type")
  externalId      String       @map("external_id") // Partner's external ID
  internalId      String       @map("internal_id") // Our internal ID
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  partner         Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, entityType, externalId])
  @@index([partnerId, entityType, externalId])
  @@index([entityType, internalId])
  @@map("external_id_mappings")
}

model ApiRequestLog {
  id              String       @id @default(uuid())
  partnerId       String?      @map("partner_id")
  partnerAppId    String?      @map("partner_app_id")
  endpoint        String
  method          String
  statusCode      Int           @map("status_code")
  duration        Int         // milliseconds
  idempotencyKey  String?       @map("idempotency_key")
  correlationId   String?       @map("correlation_id")
  requestBody     Json?         @map("request_body")
  responseBody    Json?         @map("response_body")
  errorMessage    String?       @map("error_message")
  ipAddress       String?       @map("ip_address")
  userAgent       String?       @map("user_agent")
  createdAt       DateTime     @default(now()) @map("created_at")
  partner         Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  partnerApp      PartnerApp?  @relation(fields: [partnerAppId], references: [id], onDelete: SetNull)

  @@index([partnerId, createdAt])
  @@index([partnerAppId, createdAt])
  @@index([idempotencyKey])
  @@index([correlationId])
  @@map("api_request_logs")
}

model IdempotencyKey {
  id              String       @id @default(uuid())
  partnerAppId    String       @map("partner_app_id")
  key             String       // The idempotency key (UUID)
  endpoint        String
  method          String
  requestHash     String?       @map("request_hash") // Hash of request body for validation
  responseStatus  Int           @map("response_status")
  responseBody    Json?         @map("response_body")
  createdAt       DateTime     @default(now()) @map("created_at")
  expiresAt       DateTime     @map("expires_at") // Default 24 hours
  partnerApp      PartnerApp   @relation(fields: [partnerAppId], references: [id], onDelete: Cascade)

  @@unique([partnerAppId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
}

enum PartnerEnvironment {
  SANDBOX
  PRODUCTION
}

enum PartnerAppStatus {
  ACTIVE
  REVOKED
}

enum ExternalEntityType {
  TOURNAMENT
  DIVISION
  TEAM
  PLAYER
  MATCH_DAY
  MATCHUP
  // Intelligence API entity types
  COURT
  PLAY_SESSION
  BOOKING
  MEMBER
}

// ── Intelligence Module: Enums ──

enum PlaySessionFormat {
  OPEN_PLAY
  CLINIC
  DRILL
  LEAGUE_PLAY
  SOCIAL
}

enum PlaySessionSkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum PlaySessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  NO_SHOW
}

enum WaitlistEntryStatus {
  WAITING
  PROMOTED
  EXPIRED
}

enum AIRecommendationType {
  SLOT_FILLER
  REACTIVATION
  WEEKLY_PLAN
  EVENT_INVITE
  DYNAMIC_PRICING
  REBOOKING
  AI_ADVISOR
  CHURN_PREDICTION
  GROUP_CHEMISTRY
  AUTOPILOT
  CHECK_IN
  RETENTION_BOOST
  NEW_MEMBER_WELCOME
}

// ── Intelligence Module: Models ──

model ClubCourt {
  id        String   @id @default(uuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name      String
  courtType String?
  isIndoor  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playSessions PlaySession[]

  @@map("club_courts")
}

model PlaySession {
  id          String               @id @default(uuid())
  clubId      String
  club        Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  courtId     String?
  clubCourt   ClubCourt?           @relation(fields: [courtId], references: [id])
  hostId      String?
  host        User?                @relation("PlaySessionHost", fields: [hostId], references: [id])
  title       String
  description String?
  date        DateTime
  startTime   String
  endTime     String
  format      PlaySessionFormat    @default(OPEN_PLAY)
  category    String?
  skillLevel  PlaySessionSkillLevel @default(ALL_LEVELS)
  maxPlayers  Int                  @default(8)
  pricePerSlot    Float?
  registeredCount Int?              @map("registered_count")
  status          PlaySessionStatus @default(SCHEDULED)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  bookings  PlaySessionBooking[]
  waitlist  PlaySessionWaitlist[]

  @@map("play_sessions")
}

model PlaySessionBooking {
  id        String        @id @default(uuid())
  sessionId String
  playSession PlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation("PlaySessionBookings", fields: [userId], references: [id])
  status    BookingStatus @default(CONFIRMED)
  bookedAt  DateTime      @default(now())
  cancelledAt DateTime?
  checkedInAt DateTime?

  @@unique([sessionId, userId])
  @@map("play_session_bookings")
}

model PlaySessionWaitlist {
  id        String              @id @default(uuid())
  sessionId String
  playSession PlaySession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation("PlaySessionWaitlist", fields: [userId], references: [id])
  status    WaitlistEntryStatus @default(WAITING)
  joinedAt  DateTime            @default(now())
  promotedAt DateTime?

  @@unique([sessionId, userId])
  @@map("play_session_waitlist")
}

model UserPlayPreference {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation("PlayPreferences", fields: [userId], references: [id])
  clubId                String
  club                  Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  preferredDays         String[] @default([])
  preferredTimeMorning  Boolean  @default(true)
  preferredTimeAfternoon Boolean @default(true)
  preferredTimeEvening  Boolean  @default(true)
  skillLevel            PlaySessionSkillLevel @default(ALL_LEVELS)
  preferredFormats      String[] @default([])
  targetSessionsPerWeek Int      @default(2)
  notificationsOptOut   Boolean  @default(false) @map("notifications_opt_out")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, clubId])
  @@map("user_play_preferences")
}

model AIRecommendationLog {
  id                 String                  @id @default(uuid())
  clubId             String
  club               Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId             String
  user               User                    @relation("AIRecommendationLogs", fields: [userId], references: [id])
  type               AIRecommendationType
  sessionId          String?
  channel            String?
  score              Float?
  reasoning          Json?
  status             String                  @default("pending")
  respondedAt        DateTime?
  createdAt          DateTime                @default(now())

  // ── Email/SMS Tracking (populated by Mailchimp/Twilio webhooks) ──
  externalMessageId  String?                 // Mandrill _id or Twilio MessageSid
  variantId          String?                 // Message variant used (e.g. "missed_session", "gentle_nudge")
  openedAt           DateTime?               // Email opened (Mandrill webhook)
  clickedAt          DateTime?               // Link clicked (Mandrill webhook)
  bouncedAt          DateTime?               // Email bounced (Mandrill webhook)
  deliveredAt        DateTime?               // SMS delivered (Twilio webhook)
  bounceType         String?                 // "hard" | "soft" (Mandrill bounce classification)

  // ── Sequence Chain Fields ──
  sequenceStep       Int?                    @map("sequence_step")   // Step number in chain (0, 1, 2, 3)
  parentLogId        String?                 @map("parent_log_id")   // FK to Step 0 record of this sequence
  parentLog          AIRecommendationLog?    @relation("SequenceChain", fields: [parentLogId], references: [id], onDelete: SetNull)
  childLogs          AIRecommendationLog[]   @relation("SequenceChain")

  @@index([userId, clubId, createdAt])
  @@index([userId, sessionId, type])
  @@index([externalMessageId])
  @@index([variantId, type])
  @@index([clubId, type, status])
  @@index([parentLogId])
  @@map("ai_recommendation_logs")
}

// ── AI Embeddings (RAG) ──
model DocumentEmbedding {
  id          String   @id @default(uuid())
  clubId      String   @map("club_id")
  content     String
  contentType String   @map("content_type")  // 'club_info', 'session', 'member_pattern', 'booking_trend', 'faq'
  metadata    Json     @default("{}")
  embedding   Unsupported("vector(1536)")
  sourceId    String?  @map("source_id")
  sourceTable String?  @map("source_table")
  chunkIndex  Int      @default(0) @map("chunk_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  club Club @relation("ClubEmbeddings", fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([contentType])
  @@index([sourceId, sourceTable])
  @@map("document_embeddings")
}

// ── AI Conversations ──
model AIConversation {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  userId    String   @map("user_id")
  title     String?
  language  String?  @map("language")   // auto-detected: 'en', 'ru', 'es'
  summary   String?  @map("summary")    // LLM-generated summary for cross-session memory
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  club     Club         @relation("ClubAIConversations", fields: [clubId], references: [id], onDelete: Cascade)
  user     User         @relation("UserAIConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]  @relation("ConversationMessages")
  agentDrafts AgentDraft[] @relation("ConversationAgentDrafts")

  @@index([clubId, userId])
  @@index([updatedAt(sort: Desc)])
  @@map("ai_conversations")
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String   // 'user', 'assistant', 'system'
  content        String
  metadata       Json?    @default("{}")  // token counts, model used, latency_ms
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AIConversation @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  sourceAgentDraft AgentDraft? @relation("AgentDraftSourceMessage")

  @@index([conversationId])
  @@index([createdAt])
  @@map("ai_messages")
}

model AgentDraft {
  id              String         @id @default(uuid())
  clubId          String         @map("club_id")
  conversationId  String?        @map("conversation_id")
  sourceMessageId String?        @unique @map("source_message_id")
  createdByUserId String         @map("created_by_user_id")
  kind            String
  status          String         @default("review_ready")
  title           String
  summary         String?
  originalIntent  String?        @map("original_intent")
  selectedPlan    String         @default("requested") @map("selected_plan")
  requestedAction Json           @map("requested_action")
  recommendedAction Json?        @map("recommended_action")
  workingAction   Json           @map("working_action")
  sandboxMode     Boolean        @default(false) @map("sandbox_mode")
  scheduledFor    DateTime?      @map("scheduled_for")
  timeZone        String?        @map("time_zone")
  metadata        Json           @default("{}")
  approvedAt      DateTime?      @map("approved_at")
  executedAt      DateTime?      @map("executed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  club            Club           @relation("ClubAgentDrafts", fields: [clubId], references: [id], onDelete: Cascade)
  conversation    AIConversation? @relation("ConversationAgentDrafts", fields: [conversationId], references: [id], onDelete: SetNull)
  sourceMessage   AIMessage?     @relation("AgentDraftSourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  createdByUser   User           @relation("UserAgentDrafts", fields: [createdByUserId], references: [id], onDelete: Cascade)
  opsSessionDrafts OpsSessionDraft[] @relation("AgentDraftOpsSessionDrafts")

  @@index([clubId, status, updatedAt(sort: Desc)])
  @@index([conversationId, updatedAt(sort: Desc)])
  @@index([createdByUserId, updatedAt(sort: Desc)])
  @@map("agent_drafts")
}

enum OpsSessionDraftStatus {
  READY_FOR_OPS
  SESSION_DRAFT
  REJECTED
  ARCHIVED
}

model OpsSessionDraft {
  id                       String                @id @default(uuid())
  clubId                   String                @map("club_id")
  agentDraftId             String                @map("agent_draft_id")
  createdByUserId          String                @map("created_by_user_id")
  sourceProposalId         String                @map("source_proposal_id")
  origin                   String
  status                   OpsSessionDraftStatus @default(READY_FOR_OPS)
  title                    String
  description              String?
  dayOfWeek                String                @map("day_of_week")
  timeSlot                 String                @map("time_slot")
  startTime                String                @map("start_time")
  endTime                  String                @map("end_time")
  format                   PlaySessionFormat
  skillLevel               PlaySessionSkillLevel @default(ALL_LEVELS) @map("skill_level")
  maxPlayers               Int                   @default(8) @map("max_players")
  projectedOccupancy       Int                   @map("projected_occupancy")
  estimatedInterestedMembers Int                 @map("estimated_interested_members")
  confidence               Int
  note                     String
  metadata                 Json                  @default("{}")
  sessionDraftedAt         DateTime?             @map("session_drafted_at")
  archivedAt               DateTime?             @map("archived_at")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  club                     Club                  @relation("ClubOpsSessionDrafts", fields: [clubId], references: [id], onDelete: Cascade)
  agentDraft               AgentDraft            @relation("AgentDraftOpsSessionDrafts", fields: [agentDraftId], references: [id], onDelete: Cascade)
  createdByUser            User                  @relation("UserOpsSessionDrafts", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([agentDraftId, sourceProposalId])
  @@index([clubId, status, updatedAt(sort: Desc)])
  @@index([agentDraftId, updatedAt(sort: Desc)])
  @@map("ops_session_drafts")
}

model AgentAdminTodoDecision {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  userId    String   @map("user_id")
  dateKey   String   @map("date_key")
  itemId    String   @map("item_id")
  decision  String
  title     String
  bucket    String
  href      String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club Club @relation("ClubAgentAdminTodoDecisions", fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation("UserAgentAdminTodoDecisions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId, dateKey, itemId])
  @@index([clubId, userId, dateKey, updatedAt(sort: Desc)])
  @@map("agent_admin_todo_decisions")
}

// ── Member Health Snapshots (for ML training data) ──
model MemberHealthSnapshot {
  id             String   @id @default(uuid())
  clubId         String   @map("club_id")
  userId         String   @map("user_id")
  date           DateTime @default(now())

  healthScore    Int      @map("health_score")
  riskLevel      String   @map("risk_level")      // healthy, watch, at_risk, critical
  lifecycleStage String   @map("lifecycle_stage")  // onboarding, ramping, active, at_risk, critical, churned
  features       Json     @default("{}")            // MLFeatureVector for future model training

  // Ground truth — filled retrospectively 30 days after snapshot
  actuallyChurned Boolean? @map("actually_churned")

  club Club @relation("ClubMemberHealthSnapshots", fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation("MemberHealthSnapshots", fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId, date])
  @@index([userId, date])
  @@map("member_health_snapshots")
}

model WeeklySummary {
  id          String    @id @default(uuid())
  clubId      String    @map("club_id")
  weekStart   DateTime  @map("week_start") @db.Date
  weekEnd     DateTime  @map("week_end") @db.Date
  summary     Json
  rawData     Json?     @map("raw_data")
  modelUsed   String?   @map("model_used")
  generatedAt DateTime  @default(now()) @map("generated_at")
  emailedAt   DateTime? @map("emailed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  club Club @relation("ClubWeeklySummaries", fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, weekStart])
  @@index([clubId])
  @@map("weekly_summaries")
}

model MemberAiProfile {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  clubId               String   @map("club_id")
  riskSegment          String   @default("healthy") @map("risk_segment")
  riskScore            Int      @default(50) @map("risk_score")
  preferredCategories  String[] @default([]) @map("preferred_categories")
  reactivationMessage  String?  @map("reactivation_message")
  alternativeMessage   String?  @map("alternative_message")
  slotFillerProfile    String?  @map("slot_filler_profile")
  generatedAt          DateTime @map("generated_at")
  modelUsed            String?  @map("model_used")
  generationMs         Int?     @map("generation_ms")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user  User @relation("MemberAiProfiles", fields: [userId], references: [id], onDelete: Cascade)
  club  Club @relation("MemberAiProfiles", fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([clubId])
  @@index([userId])
  @@index([riskSegment])
  @@map("member_ai_profiles")
}

model SessionInterestRequest {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  clubId             String    @map("club_id")
  preferredDays      String[]  @default([]) @map("preferred_days")
  preferredFormats   String[]  @default([]) @map("preferred_formats")
  preferredTimeSlots Json      @default("{}") @map("preferred_time_slots")
  token              String    @unique
  status             String    @default("pending")
  notifiedAt         DateTime? @map("notified_at")
  sessionId          String?   @map("session_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation("SessionInterestRequests", fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation("SessionInterestRequests", fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([clubId])
  @@index([status])
  @@map("session_interest_requests")
}
