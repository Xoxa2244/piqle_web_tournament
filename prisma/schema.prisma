generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                    @id @default(uuid())
  email                    String                    @unique
  name                     String?
  image                    String?
  emailVerified            DateTime?
  passwordHash             String?                   @map("password_hash")
  role                     UserRole                  @default(TD)
  isActive                 Boolean                   @default(true)
  gender                   Gender?
  city                     String?
  duprLink                 String?
  duprId                   String?                   @map("dupr_id")
  duprNumericId            BigInt?                   @map("dupr_numeric_id")
  duprAccessToken          String?                   @map("dupr_access_token")
  duprRefreshToken         String?                   @map("dupr_refresh_token")
  duprRatingSingles        Decimal?                  @map("dupr_rating_singles") @db.Decimal(4, 2)
  duprRatingDoubles        Decimal?                  @map("dupr_rating_doubles") @db.Decimal(4, 2)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  accounts                 Account[]
  assistantAssignments     AssistantAssignment[]
  auditLogs                AuditLog[]
  clubFollows              ClubFollower[]
  clubAdminRoles           ClubAdmin[]
  clubAnnouncementsCreated ClubAnnouncement[]         @relation("ClubAnnouncementCreatedBy")
  clubBookingRequestsCreated ClubBookingRequest[]     @relation("ClubBookingRequestRequestedBy")
  clubChatMessages         ClubChatMessage[]
  clubChatReadStates       ClubChatReadState[]
  tournamentChatMessages   TournamentChatMessage[]
  tournamentChatReadStates TournamentChatReadState[]
  divisionChatMessages     DivisionChatMessage[]
  divisionChatReadStates   DivisionChatReadState[]
  clubInvitesSent          ClubInvite[]              @relation("ClubInviteInviter")
  clubInvitesReceived      ClubInvite[]              @relation("ClubInviteInvitee")
  clubJoinRequests         ClubJoinRequest[]
  clubJoinRequestSeen      ClubJoinRequestSeen[]
  clubBans                 ClubBan[]
  clubBansIssued           ClubBan[]                 @relation("ClubBanBannedBy")
  clubTournamentTemplatesCreated ClubTournamentTemplate[] @relation("ClubTournamentTemplateCreatedBy")
  clubTournamentTemplatesUpdated ClubTournamentTemplate[] @relation("ClubTournamentTemplateUpdatedBy")
  players                  Player[]
  sessions                 Session[]
  tournaments              Tournament[]
  tournamentAccesses       TournamentAccess[]
  tournamentAccessRequests TournamentAccessRequest[]
  tournamentRatings        TournamentRating[]
  tournamentComments       TournamentComment[]
  partnerDirectorships     Partner[] // Partners where this user is the director
  organizerStripeAccountId String?                   @map("organizer_stripe_account_id")
  stripeOnboardingComplete Boolean                   @default(false) @map("stripe_onboarding_complete")
  tournamentInvitationsReceived TournamentInvitation[] @relation("InvitedUser")
  stripeCustomerId         String?                   @map("stripe_customer_id")
  stripeDefaultPaymentMethodId String?               @map("stripe_default_payment_method_id")
  stripeDefaultCardBrand   String?                   @map("stripe_default_card_brand")
  stripeDefaultCardLast4   String?                   @map("stripe_default_card_last4")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @id
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailOtp {
  id           String   @id @default(uuid())
  email        String   @unique
  codeHash     String
  expiresAt    DateTime
  attemptsLeft Int      @default(5)
  lastSentAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("email_otps")
}

model Tournament {
  id                      String                    @id @default(uuid())
  title                   String
  description             String?
  rulesUrl                String?
  venueName               String?
  venueAddress            String?
  clubId                  String?                   @map("club_id")
  startDate               DateTime
  endDate                 DateTime
  registrationStartDate   DateTime?                 @map("registration_start_date")
  registrationEndDate     DateTime?                 @map("registration_end_date")
  entryFee                Decimal?                  @db.Decimal(10, 2)
  entryFeeCents           Int?                      @map("entry_fee_cents")
  currency                String                    @default("usd")
  paymentTiming           PaymentTiming             @default(PAY_IN_15_MIN) @map("payment_timing")
  isPublicBoardEnabled    Boolean                   @default(false)
  publicSlug              String?                   @unique
  image                   String?
  format                  TournamentFormat          @default(SINGLE_ELIMINATION)
  allowDuprSubmission     Boolean                   @default(false) @map("allow_dupr_submission")
  seasonLabel             String?                   @map("season_label")
  timezone                String?
  hasDivisions            Boolean                   @default(true) @map("has_divisions")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  userId                  String
  auditLogs               AuditLog[]
  divisions               Division[]
  importJobs              ImportJob[]
  players                 Player[]
  prizes                  Prize[]
  rrGroups                RoundRobinGroup[]
  tournamentAccesses      TournamentAccess[]
  tournamentRatings       TournamentRating[]
  tournamentComments     TournamentComment[]
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tournaments_userid_fkey")
  TournamentAccessRequest TournamentAccessRequest[]
  matchDays               MatchDay[]
  courts                  Court[]
  waitlistEntries         WaitlistEntry[]
  payments                Payment[]
  tournamentInvitations   TournamentInvitation[]
  chatMessages            TournamentChatMessage[]
  chatReadStates          TournamentChatReadState[]
  club                    Club?                     @relation(fields: [clubId], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@map("tournaments")
}

model TournamentInvitation {
  id             String                 @id @default(uuid())
  tournamentId   String                 @map("tournament_id")
  invitedUserId  String                 @map("invited_user_id")
  email          String                 // Denormalized for the email we sent
  status         TournamentInvitationStatus @default(PENDING)
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  tournament     Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  invitedUser    User                   @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, invitedUserId])
  @@map("tournament_invitations")
}

model Club {
  id                 String               @id @default(uuid())
  name               String
  kind               ClubKind             @default(VENUE)
  joinPolicy         ClubJoinPolicy       @default(OPEN) @map("join_policy")
  description        String?
  logoUrl            String?              @map("logo_url")
  address            String?
  city               String?
  state              String?
  country            String?
  isVerified         Boolean              @default(false) @map("is_verified")
  courtReserveUrl    String?              @map("court_reserve_url")
  bookingRequestEmail String?             @map("booking_request_email")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  tournaments        Tournament[]
  tournamentTemplates ClubTournamentTemplate[]
  followers          ClubFollower[]
  joinRequests       ClubJoinRequest[]
  joinRequestSeen    ClubJoinRequestSeen[]
  admins             ClubAdmin[]
  announcements      ClubAnnouncement[]
  bookingRequests    ClubBookingRequest[]
  chatMessages       ClubChatMessage[]
  chatReadStates     ClubChatReadState[]
  invites            ClubInvite[]
  bans               ClubBan[]

  @@map("clubs")
}

model ClubFollower {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
  @@map("club_followers")
}

model ClubJoinRequest {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId, createdAt])
  @@index([userId])
  @@map("club_join_requests")
}

model ClubJoinRequestSeen {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  clubId    String   @map("club_id")
  seenAt    DateTime @default(now()) @map("seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
  @@map("club_join_request_seen")
}

model ClubAdmin {
  id        String        @id @default(uuid())
  clubId    String        @map("club_id")
  userId    String        @map("user_id")
  role      ClubAdminRole @default(ADMIN)
  createdAt DateTime      @default(now()) @map("created_at")

  club      Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
  @@map("club_admins")
}

model ClubAnnouncement {
  id              String   @id @default(uuid())
  clubId          String   @map("club_id")
  title           String?
  body            String
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdByUser   User?    @relation("ClubAnnouncementCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt])
  @@map("club_announcements")
}

model ClubBookingRequest {
  id              String                  @id @default(uuid())
  clubId          String                  @map("club_id")
  requesterUserId String?                 @map("requester_user_id")
  requesterName   String                  @map("requester_name")
  requesterEmail  String                  @map("requester_email")
  requesterPhone  String?                 @map("requester_phone")
  desiredStart    DateTime?               @map("desired_start")
  durationMinutes Int?                    @map("duration_minutes")
  playersCount    Int?                    @map("players_count")
  message         String?                 @map("message")
  status          ClubBookingRequestStatus @default(NEW)
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  club            Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  requesterUser   User?                   @relation("ClubBookingRequestRequestedBy", fields: [requesterUserId], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt])
  @@index([requesterUserId])
  @@map("club_booking_requests")
}

model ClubChatMessage {
  id              String   @id @default(uuid())
  clubId          String   @map("club_id")
  userId          String   @map("user_id")
  text            String
  deletedAt       DateTime? @map("deleted_at")
  deletedByUserId String?  @map("deleted_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
  @@index([userId])
  @@map("club_chat_messages")
}

model TournamentChatMessage {
  id              String    @id @default(uuid())
  tournamentId    String    @map("tournament_id")
  userId          String    @map("user_id")
  text            String
  deletedAt       DateTime? @map("deleted_at")
  deletedByUserId String?   @map("deleted_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tournamentId, createdAt])
  @@index([userId])
  @@map("tournament_chat_messages")
}

model DivisionChatMessage {
  id              String    @id @default(uuid())
  divisionId      String    @map("division_id")
  userId          String    @map("user_id")
  text            String
  deletedAt       DateTime? @map("deleted_at")
  deletedByUserId String?   @map("deleted_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([divisionId, createdAt])
  @@index([userId])
  @@map("division_chat_messages")
}

model ClubChatReadState {
  id         String   @id @default(uuid())
  clubId     String   @map("club_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId, updatedAt])
  @@map("club_chat_read_states")
}

model TournamentChatReadState {
  id           String   @id @default(uuid())
  tournamentId String   @map("tournament_id")
  userId       String   @map("user_id")
  lastReadAt   DateTime @default(now()) @map("last_read_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([userId, updatedAt])
  @@map("tournament_chat_read_states")
}

model DivisionChatReadState {
  id         String   @id @default(uuid())
  divisionId String   @map("division_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([divisionId, userId])
  @@index([userId, updatedAt])
  @@map("division_chat_read_states")
}

model ClubInvite {
  id            String   @id @default(uuid())
  clubId        String   @map("club_id")
  inviterUserId String   @map("inviter_user_id")
  inviteeUserId String?  @map("invitee_user_id")
  inviteeEmail  String   @map("invitee_email")
  delivered     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  club    Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  inviter User @relation("ClubInviteInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitee User? @relation("ClubInviteInvitee", fields: [inviteeUserId], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt])
  @@index([inviterUserId, createdAt])
  @@index([inviteeEmail])
  @@map("club_invites")
}

model ClubBan {
  id             String   @id @default(uuid())
  clubId         String   @map("club_id")
  userId         String   @map("user_id")
  bannedByUserId String   @map("banned_by_user_id")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  club        Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bannedByUser User @relation("ClubBanBannedBy", fields: [bannedByUserId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId, createdAt])
  @@index([userId])
  @@map("club_bans")
}

model ClubTournamentTemplate {
  id              String   @id @default(uuid())
  clubId          String   @map("club_id")
  name            String
  description     String?
  config          Json
  schemaVersion   Int      @default(1) @map("schema_version")
  createdByUserId String   @map("created_by_user_id")
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  club          Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdByUser User  @relation("ClubTournamentTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  updatedByUser User? @relation("ClubTournamentTemplateUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([clubId, name])
  @@index([clubId, updatedAt])
  @@map("club_tournament_templates")
}

model Court {
  id           String      @id @default(uuid())
  tournamentId String      @map("tournament_id")
  name         String
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchups     IndyMatchup[]

  @@map("courts")
}

model Prize {
  id           String     @id @default(uuid())
  tournamentId String
  divisionId   String?
  place        Int
  label        String
  amount       Decimal?   @db.Decimal(10, 2)
  kind         PrizeKind  @default(CASH)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  division     Division?  @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("prizes")
}

model Division {
  id                    String                @id @default(uuid())
  tournamentId          String
  name                  String
  teamKind              TeamKind
  pairingMode           PairingMode
  maxTeams              Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  stage                 DivisionStage?        @default(RR_IN_PROGRESS)
  poolCount             Int                   @default(1)
  isMerged              Boolean               @default(false)
  mergedFromDivisionIds Json? // Array of division IDs that were merged into this division
  assistantAssignments  AssistantAssignment[]
  constraints           DivisionConstraints?
  rrBindings            DivisionRRBinding[]
  tournament            Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches               Match[]
  pools                 Pool[]
  prizes                Prize[]
  standings             Standing[]
  teams                 Team[]
  waitlistEntries       WaitlistEntry[]
  tournamentAccesses    TournamentAccess[]
  indyMatchups          IndyMatchup[]
  chatMessages          DivisionChatMessage[]
  chatReadStates        DivisionChatReadState[]

  @@map("divisions")
}

model DivisionConstraints {
  id         String           @id @default(uuid())
  divisionId String           @unique
  minDupr    Decimal?         @db.Decimal(4, 2)
  maxDupr    Decimal?         @db.Decimal(4, 2)
  minTeamDupr Decimal?        @db.Decimal(4, 2)
  maxTeamDupr Decimal?        @db.Decimal(4, 2)
  minAge     Int?
  maxAge     Int?
  genders    GenderConstraint @default(ANY)
  enforcement ConstraintEnforcement @default(INFO)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  division   Division         @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@map("division_constraints")
}

model AssistantAssignment {
  id         String   @id @default(uuid())
  userId     String
  divisionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, divisionId])
  @@map("assistant_assignments")
}

model Pool {
  id         String     @id @default(uuid())
  divisionId String
  name       String
  order      Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  matches    Match[]
  division   Division   @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  standings  Standing[]
  teams      Team[]

  @@map("pools")
}

model Team {
  id          String       @id @default(uuid())
  divisionId  String
  poolId      String?
  name        String
  seed        Int?
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  matchesAsA          Match[]         @relation("TeamA")
  matchesAsB          Match[]         @relation("TeamB")
  homeMatchups        IndyMatchup[]   @relation("HomeTeam")
  awayMatchups        IndyMatchup[]   @relation("AwayTeam")
  tieBreakWinnerMatchups IndyMatchup[] @relation("TieBreakWinnerTeam")
  standings           Standing[]
  teamPlayers         TeamPlayer[]
  dayRosters          DayRoster[]
  payments            Payment[]
  division            Division        @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  pool                Pool?           @relation(fields: [poolId], references: [id])

  @@map("teams")
}

model Player {
  id                String       @id @default(uuid())
  firstName         String       @map("firstName")
  lastName          String       @map("lastName")
  email             String?
  userId            String?      @map("user_id")
  gender            Gender?
  birthDate         DateTime?    @map("birthDate")
  externalId        String?      @map("externalId")
  createdAt         DateTime     @default(now()) @map("createdAt")
  updatedAt         DateTime     @updatedAt @map("updatedAt")
  duprRating        Decimal?     @map("dupr_rating") @db.Decimal(3, 2)
  isPaid            Boolean?     @default(false) @map("is_paid")
  isWaitlist        Boolean?     @default(false) @map("is_waitlist")
  dupr              String?      @db.VarChar
  tournamentId      String?      @map("tournament_id")
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tournament        Tournament?  @relation(fields: [tournamentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  waitlistEntries   WaitlistEntry[]
  teamPlayers       TeamPlayer[]
  dayRosters        DayRoster[]
  indyGamesAsHome1  IndyGame[]   @relation("IndyGameHomePlayer1")
  indyGamesAsHome2  IndyGame[]   @relation("IndyGameHomePlayer2")
  indyGamesAsAway1  IndyGame[]   @relation("IndyGameAwayPlayer1")
  indyGamesAsAway2  IndyGame[]   @relation("IndyGameAwayPlayer2")
  payments          Payment[]

  @@unique([userId, tournamentId])
  @@map("players")
}

model TeamPlayer {
  id        String     @id @default(uuid())
  teamId    String     @map("teamId")
  playerId  String     @map("playerId")
  role      PlayerRole @default(PLAYER)
  slotIndex Int?       @map("slot_index")
  createdAt DateTime   @default(now()) @map("createdAt")
  updatedAt DateTime   @updatedAt @map("updatedAt")
  player    Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@unique([teamId, slotIndex])
  @@map("team_players")
}

model Payment {
  id                      String        @id @default(uuid())
  tournamentId            String        @map("tournament_id")
  playerId                String        @map("player_id")
  teamId                  String?       @map("team_id")
  slotIndex               Int?          @map("slot_index")
  entryFeeAmount          Decimal       @db.Decimal(10, 2) @map("entry_fee_amount")
  platformFeeAmount       Decimal       @db.Decimal(10, 2) @map("platform_fee_amount")
  stripeFeeAmount         Decimal       @db.Decimal(10, 2) @map("stripe_fee_amount")
  totalAmount             Decimal       @db.Decimal(10, 2) @map("total_amount")
  currency                String        @default("usd")
  status                  PaymentStatus @default(PENDING)
  dueAt                   DateTime?     @map("due_at")
  stripeCheckoutSessionId String?       @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?       @map("stripe_payment_intent_id")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")
  tournament              Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player                  Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team                    Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([tournamentId, playerId])
  @@index([status])
  @@map("payments")
}

model WaitlistEntry {
  id           String         @id @default(uuid())
  tournamentId String         @map("tournament_id")
  divisionId   String         @map("division_id")
  playerId     String         @map("player_id")
  status       WaitlistStatus @default(ACTIVE)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  tournament   Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division     Division       @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  player       Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, tournamentId])
  @@index([divisionId, createdAt])
  @@map("waitlist_entries")
}

model RoundRobinGroup {
  id           String              @id @default(uuid())
  tournamentId String
  name         String
  rrSettingsId String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  bindings     DivisionRRBinding[]
  matches      Match[]
  rrSettings   RRSettings          @relation(fields: [rrSettingsId], references: [id], onDelete: Cascade)
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  standings    Standing[]

  @@map("round_robin_groups")
}

model RRSettings {
  id            String            @id @default(uuid())
  targetPoints  Int               @default(11)
  winBy         Int               @default(2)
  gamesPerMatch Int               @default(1)
  bestOfMode    BestOfMode        @default(FIXED_GAMES)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  rrGroups      RoundRobinGroup[]

  @@map("rr_settings")
}

model DivisionRRBinding {
  id         String          @id @default(uuid())
  divisionId String
  rrGroupId  String
  status     BindingStatus   @default(BOUND)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  division   Division        @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  rrGroup    RoundRobinGroup @relation(fields: [rrGroupId], references: [id], onDelete: Cascade)

  @@unique([divisionId, rrGroupId])
  @@map("division_rr_bindings")
}

model Match {
  id                    String                @id @default(uuid())
  rrGroupId             String?
  divisionId            String?
  poolId                String?
  roundIndex            Int
  stage                 MatchStage
  teamAId               String
  teamBId               String
  bestOfMode            BestOfMode
  gamesCount            Int
  targetPoints          Int
  winBy                 Int
  winnerTeamId          String?
  locked                Boolean                @default(false)
  sendToDupr            Boolean                @default(false) @map("send_to_dupr")
  duprSubmissionStatus  DuprSubmissionStatus?  @default(PENDING) @map("dupr_submission_status")
  duprMatchId           String?               @map("dupr_match_id")
  duprSubmissionError   String?               @map("dupr_submission_error")
  duprSubmittedAt       DateTime?             @map("dupr_submitted_at")
  duprRetryCount        Int                   @default(0) @map("dupr_retry_count")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  note                  String?                @db.VarChar(255)
  matchDayId            String?                @map("match_day_id")
  games                 Game[]
  tiebreaker            Tiebreaker?
  division     Division?        @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  pool         Pool?            @relation(fields: [poolId], references: [id], onDelete: Cascade)
  rrGroup      RoundRobinGroup? @relation(fields: [rrGroupId], references: [id], onDelete: Cascade)
  matchDay     MatchDay?        @relation(fields: [matchDayId], references: [id], onDelete: SetNull)
  teamA        Team             @relation("TeamA", fields: [teamAId], references: [id], onDelete: Cascade)
  teamB        Team             @relation("TeamB", fields: [teamBId], references: [id], onDelete: Cascade)

  @@map("matches")
}

model Game {
  id        String      @id @default(uuid())
  matchId   String
  index     Int
  scoreA    Int? // Nullable - empty until score is entered
  scoreB    Int? // Nullable - empty until score is entered
  winner    GameWinner?
  gameType  GameType? // For MLP: WOMEN, MEN, MIXED_1, MIXED_2
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, index])
  @@map("games")
}

model Tiebreaker {
  id           String   @id @default(uuid())
  matchId      String   @unique
  teamAScore   Int      @default(0)
  teamBScore   Int      @default(0)
  winnerTeamId String?
  sequence     Json? // Array of { order, teamAPlayerId, teamBPlayerId } - optional
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("tiebreakers")
}

model Standing {
  id            String           @id @default(uuid())
  rrGroupId     String?
  divisionId    String?
  poolId        String?
  teamId        String
  wins          Int              @default(0)
  losses        Int              @default(0)
  pointsFor     Int              @default(0)
  pointsAgainst Int              @default(0)
  pointDiff     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  division      Division?        @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  pool          Pool?            @relation(fields: [poolId], references: [id], onDelete: Cascade)
  rrGroup       RoundRobinGroup? @relation(fields: [rrGroupId], references: [id], onDelete: Cascade)
  team          Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([rrGroupId, teamId])
  @@unique([divisionId, teamId])
  @@unique([poolId, teamId])
  @@map("standings")
}

model ImportJob {
  id           String       @id @default(uuid())
  tournamentId String
  source       ImportSource @default(PBT_CSV)
  status       ImportStatus @default(PENDING)
  mappingJson  Json?
  rawFileUrl   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("import_jobs")
}

model AuditLog {
  id           String     @id @default(uuid())
  actorUserId  String
  tournamentId String
  action       String
  entityType   String
  entityId     String
  payload      Json?
  createdAt    DateTime   @default(now())
  actor        User       @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model TournamentAccess {
  id           String      @id @default(uuid())
  userId       String
  tournamentId String
  divisionId   String? // null = access to all divisions
  accessLevel  AccessLevel @default(SCORE_ONLY)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division?  @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId, divisionId])
  @@map("tournament_accesses")
}

model TournamentAccessRequest {
  id           String              @id @default(uuid())
  userId       String
  tournamentId String
  status       AccessRequestStatus @default(PENDING)
  message      String? // Optional message from requester
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId]) // One request per user per tournament
  @@map("tournament_access_requests")
}

model TournamentRating {
  id           String     @id @default(uuid())
  tournamentId String
  userId       String
  rating       RatingType
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId]) // One rating per user per tournament
  @@map("tournament_ratings")
}

model TournamentComment {
  id           String     @id @default(uuid())
  tournamentId String
  userId       String
  text         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tournamentId, createdAt])
  @@map("tournament_comments")
}

model MatchDay {
  id           String          @id @default(uuid())
  tournamentId String           @map("tournament_id")
  date         DateTime         @db.Date
  status       MatchDayStatus   @default(DRAFT)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchups     IndyMatchup[]
  rrMatches    Match[]          // League Round Robin: RR matches for this day

  @@unique([tournamentId, date])
  @@map("match_days")
}

model IndyMatchup {
  id                  String          @id @default(uuid())
  matchDayId          String           @map("match_day_id")
  divisionId          String           @map("division_id")
  homeTeamId          String           @map("home_team_id")
  awayTeamId          String           @map("away_team_id")
  courtId             String?          @map("court_id")
  tieBreakWinnerTeamId String?         @map("tie_break_winner_team_id")
  gamesWonHome        Int             @default(0) @map("games_won_home")
  gamesWonAway        Int             @default(0) @map("games_won_away")
  status              MatchupStatus   @default(PENDING)
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  matchDay            MatchDay         @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  division            Division         @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  homeTeam            Team             @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam            Team             @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  court               Court?           @relation(fields: [courtId], references: [id], onDelete: SetNull)
  tieBreakWinnerTeam  Team?            @relation("TieBreakWinnerTeam", fields: [tieBreakWinnerTeamId], references: [id], onDelete: SetNull)
  rosters             DayRoster[]
  games                IndyGame[]

  @@map("indy_matchups")
}

model DayRoster {
  id        String      @id @default(uuid())
  matchupId String      @map("matchup_id")
  teamId    String      @map("team_id")
  playerId  String      @map("player_id")
  isActive  Boolean     @default(false) @map("is_active")
  letter    String?     @db.VarChar(1) // A, B, C, or D
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  matchup   IndyMatchup @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchupId, teamId, playerId])
  @@map("day_rosters")
}

model IndyGame {
  id        String      @id @default(uuid())
  matchupId String      @map("matchup_id")
  order     Int         // 1-12
  court     Int         // 1 or 2
  homePair  String      @map("home_pair") @db.VarChar(2) // AB, CD, AC, BD, AD, BC
  awayPair  String      @map("away_pair") @db.VarChar(2) // AB, CD, AC, BD, AD, BC
  homeScore Int?        @map("home_score")
  awayScore Int?        @map("away_score")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  matchup   IndyMatchup @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  homePlayer1Id String?     @map("home_player1_id") // Player ID for first letter in homePair
  homePlayer2Id String?     @map("home_player2_id") // Player ID for second letter in homePair
  awayPlayer1Id String?     @map("away_player1_id") // Player ID for first letter in awayPair
  awayPlayer2Id String?     @map("away_player2_id") // Player ID for second letter in awayPair
  homePlayer1   Player?     @relation("IndyGameHomePlayer1", fields: [homePlayer1Id], references: [id], onDelete: SetNull)
  homePlayer2   Player?     @relation("IndyGameHomePlayer2", fields: [homePlayer2Id], references: [id], onDelete: SetNull)
  awayPlayer1   Player?     @relation("IndyGameAwayPlayer1", fields: [awayPlayer1Id], references: [id], onDelete: SetNull)
  awayPlayer2   Player?     @relation("IndyGameAwayPlayer2", fields: [awayPlayer2Id], references: [id], onDelete: SetNull)

  @@unique([matchupId, order])
  @@map("indy_games")
}

