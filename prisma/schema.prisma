  DISLIKE
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  ROUND_ROBIN
  MLP
  INDY_LEAGUE
  LEAGUE_ROUND_ROBIN
  ONE_DAY_LADDER
  LADDER_LEAGUE
