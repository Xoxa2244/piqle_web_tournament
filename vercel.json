{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/payments/process-due",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/campaigns/health",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/campaigns/weekly-summary",
      "schedule": "0 15 * * 1"
    },
    {
      "path": "/api/emails/trial-reminder",
      "schedule": "0 14 * * *"
    }
  ]
}
