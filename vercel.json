{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/payments/process-due",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/campaigns/health",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/campaigns/weekly-summary",
      "schedule": "0 15 * * 1"
    },
    {
      "path": "/api/emails/trial-reminder",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/connectors/courtreserve/sync",
      "schedule": "17 * * * *"
    },
    {
      "path": "/api/ai/generate-member-profiles",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/campaigns/conversion-check",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/campaigns/calibrate-weights",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/campaigns/review-request",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/campaigns/morning-digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/agent/events",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/ai/sync-embeddings",
      "schedule": "0 3 * * *"
    }
  ]
}
