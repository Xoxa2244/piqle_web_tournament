# ============================================
# Environment Variables Template
# Copy this file to .env.local and fill in values
# cp .env.example .env.local
# ============================================

# ── Database (Supabase PostgreSQL) ──
# Get from: Supabase Dashboard → Settings → Database
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&prepared_statements=false"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── Stripe ──
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── App URL ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google Maps ──
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── AI Provider Keys ──
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── AI Model Config ──
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS="1536"
AI_PRIMARY_MODEL="gpt-4o-mini"
AI_FALLBACK_MODEL="claude-3-5-haiku-20241022"
AI_PREMIUM_MODEL="gpt-4o"

# ── Mailchimp / Mandrill (transactional email) ──
# Get from: https://mandrillapp.com/settings
MAILCHIMP_TRANSACTIONAL_API_KEY=""
MAILCHIMP_WEBHOOK_KEY=""

# ── Twilio SMS ──
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID=""
