# ============================================
# Environment Variables Template
# Copy this file to .env.local and fill in values
# cp .env.example .env.local
# ============================================

# ── Database (Supabase PostgreSQL) ──
# Get from: Supabase Dashboard → Settings → Database
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&prepared_statements=false"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── NextAuth ──
# Generate: openssl rand -base64 64
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (SMTP for magic links) ──
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@iqsport.ai"

# ── Cron Jobs (required!) ──
# Used by: /api/agent/events, /api/agent/admin-reminders, /api/campaigns/*,
#          and HMAC signing for approve/skip/snooze email links.
# Generate: openssl rand -hex 32
CRON_SECRET=""

# ── Encryption (for storing integration credentials) ──
# Generate: openssl rand -hex 32
CONNECTOR_ENCRYPTION_KEY=""

# ── Stripe ──
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Separate secret for subscription webhooks (if configured in Stripe dashboard)
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=""

# ── App URL ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google Maps ──
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── AI Provider Keys ──
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── AI Model Config ──
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS="1536"
AI_PRIMARY_MODEL="gpt-4o-mini"
AI_FALLBACK_MODEL="claude-3-5-haiku-20241022"
AI_PREMIUM_MODEL="gpt-4o"

# ── Mailchimp / Mandrill (transactional email) ──
# Get from: https://mandrillapp.com/settings
MAILCHIMP_TRANSACTIONAL_API_KEY=""
MAILCHIMP_WEBHOOK_KEY=""

# ── Resend (alternative email provider) ──
# Only if using Resend for outreach — otherwise leave blank
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# ── Twilio SMS ──
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID=""

# ── Agent Rollout Controls ──
# Comma-separated list of club IDs that can receive member-facing agent outreach.
# Empty = no clubs enabled (safe default). Example: "club-uuid-1,club-uuid-2"
AGENT_OUTREACH_ROLLOUT_CLUB_IDS=""

# ── Rate Limiting (Upstash Redis) ──
# Required in production. Without these, rate limits silently disable —
# leaves agent approve/skip/snooze links vulnerable to token brute-force.
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Sentry (error tracking) ──
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── Superadmin Access ──
# Comma-separated user IDs and/or emails allowed to access superadmin features
SUPERADMIN_USER_ID_ALLOWLIST=""
SUPERADMIN_EMAIL_ALLOWLIST=""

# ── Logging ──
LOG_LEVEL="info"
